# Porta do servidor HTTP
PORT=3000

# Provider de cotação: "mock" (desenvolvimento, sem credenciais) ou "correios" (produção)
SHIPPING_PROVIDER=mock

# ── Credenciais Correios (CWS - api.correios.com.br) ────────────────────────
# Exigem contrato com os Correios. Obtenha em https://cws.correios.com.br
# Usuário do Meu Correios:
CORREIOS_USER=
# Código de acesso à API (gerado no portal CWS, NÃO é a senha do Meu Correios):
CORREIOS_ACCESS_CODE=
# Número do cartão de postagem do contrato:
CORREIOS_POSTAGE_CARD=

# Códigos de serviço a cotar, separados por vírgula.
# 03220 = SEDEX CONTRATO AG | 03298 = PAC CONTRATO AG
CORREIOS_SERVICES=03220,03298

# Tempo de vida do cache de cotações, em segundos (0 desativa)
QUOTE_CACHE_TTL_SECONDS=300

# Timeout de chamadas à API dos Correios, em milissegundos
CORREIOS_TIMEOUT_MS=10000
